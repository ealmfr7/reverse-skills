{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema", "type", "event", "ts", "source", "data"],
  "properties": {
    "schema": { "const": 1 },
    "type": { "enum": ["event", "status", "blob", "error"] },
    "event": { "type": "string", "minLength": 1 },
    "ts": { "type": "number" },
    "source": { "type": "string", "minLength": 1 },
    "data": { "type": "object" }
  },
  "additionalProperties": true
}

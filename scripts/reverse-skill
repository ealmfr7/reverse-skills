#!/usr/bin/env python3
from __future__ import annotations

import os
import json
import shutil
import subprocess
import sys
from pathlib import Path


PLUGIN_NAME = "reverse-skills"


def repo_root() -> Path:
    return Path(__file__).resolve().parents[1]


def candidate_roots() -> list[Path]:
    home = Path.home()
    roots = [
        repo_root(),
        home / "plugins" / PLUGIN_NAME / "skills",
        home / ".codex" / "plugins" / "cache" / "personal" / PLUGIN_NAME,
    ]
    account_cache = home / ".codex-account-cli" / "homes"
    if account_cache.exists():
        roots.extend(account_cache.glob(f"*/plugins/cache/personal/{PLUGIN_NAME}/*/skills"))
    return roots


def candidate_root_records() -> list[dict[str, object]]:
    home = Path.home()
    records: list[dict[str, object]] = [
        {"kind": "repo", "path": repo_root()},
        {"kind": "local-plugin", "path": home / "plugins" / PLUGIN_NAME / "skills"},
        {
            "kind": "codex-cache",
            "path": home / ".codex" / "plugins" / "cache" / "personal" / PLUGIN_NAME,
        },
    ]
    account_cache = home / ".codex-account-cli" / "homes"
    if account_cache.exists():
        for path in sorted(account_cache.glob(f"*/plugins/cache/personal/{PLUGIN_NAME}/*/skills")):
            records.append({"kind": "account-cache", "path": path})
    return records


def skills_root(root: Path) -> Path:
    if (root / "skills").is_dir():
        return root / "skills"
    return root


def skill_dirs() -> dict[str, Path]:
    found: dict[str, Path] = {}
    for root in candidate_roots():
        base = skills_root(root)
        if not base.exists():
            continue
        for skill_file in base.glob("*/SKILL.md"):
            found.setdefault(skill_file.parent.name, skill_file.parent)
    return dict(sorted(found.items()))


def normalize_tool_name(name: str) -> list[str]:
    path = Path(name)
    if path.suffix:
        return [name]
    return [name, f"{name}.py", f"{name}.sh", f"{name}.js"]


def is_public_tool(path: Path) -> bool:
    if "__pycache__" in path.parts or path.suffix == ".pyc" or path.name.startswith("."):
        return False
    if path.name == "common.py":
        return False
    return True


def resolve_tool(skill: str, tool: str) -> Path:
    skills = skill_dirs()
    if skill not in skills:
        available = ", ".join(skills)
        raise SystemExit(f"Unknown skill: {skill}\nAvailable skills: {available}")
    scripts = skills[skill] / "scripts"
    for candidate in normalize_tool_name(tool):
        path = scripts / candidate
        if path.exists() and path.is_file() and is_public_tool(path):
            return path
    available = []
    if scripts.exists():
        for path in sorted(item for item in scripts.rglob("*") if item.is_file() and is_public_tool(item)):
            available.append(str(path.relative_to(scripts)))
    raise SystemExit(
        f"Unknown tool for {skill}: {tool}\nAvailable tools: {', '.join(available)}"
    )


def list_skills() -> int:
    for name in skill_dirs():
        print(name)
    return 0


def list_tools(skill: str) -> int:
    skills = skill_dirs()
    if skill not in skills:
        raise SystemExit(f"Unknown skill: {skill}")
    scripts = skills[skill] / "scripts"
    if not scripts.exists():
        return 0
    for path in sorted(item for item in scripts.rglob("*") if item.is_file() and is_public_tool(item)):
        rel = path.relative_to(scripts)
        if path.suffix in {".py", ".sh", ".js"}:
            print(str(rel.with_suffix("")))
        else:
            print(rel)
    return 0


def command_for(path: Path, args: list[str]) -> list[str]:
    if path.suffix == ".py":
        return ["python3", str(path), *args]
    if path.suffix == ".sh":
        return ["bash", str(path), *args]
    if os.access(path, os.X_OK):
        return [str(path), *args]
    return [str(path), *args]


def doctor_data() -> dict[str, object]:
    skills = skill_dirs()
    roots = []
    for record in candidate_root_records():
        path = Path(record["path"])
        base = skills_root(path)
        roots.append(
            {
                "kind": record["kind"],
                "path": str(path),
                "exists": path.exists(),
                "skillsPath": str(base),
                "skillsPathExists": base.exists(),
                "skillCount": len(list(base.glob("*/SKILL.md"))) if base.exists() else 0,
            }
        )

    tools = {}
    for name in [
        "python3",
        "bash",
        "git",
        "codex",
        "adb",
        "frida",
        "jadx",
        "apktool",
        "tshark",
        "ghidra_analyzeHeadless",
    ]:
        tools[name] = shutil.which(name)

    return {
        "cli": {
            "path": str(Path(__file__).resolve()),
            "onPath": shutil.which("reverse-skill"),
        },
        "plugin": {
            "name": PLUGIN_NAME,
        },
        "roots": roots,
        "skills": {
            "count": len(skills),
            "names": list(skills),
        },
        "tools": tools,
    }


def doctor(json_output: bool = False) -> int:
    data = doctor_data()
    if json_output:
        print(json.dumps(data, indent=2, sort_keys=True))
        return 0

    print("Reverse Skill Doctor")
    print(f"cli: {data['cli']['path']}")
    print(f"cli_on_path: {data['cli']['onPath'] or 'missing'}")
    print(f"plugin: {data['plugin']['name']}")
    print(f"skills: {data['skills']['count']}")
    print("roots:")
    for root in data["roots"]:
        status = "ok" if root["skillsPathExists"] else "missing"
        print(f"  - {root['kind']}: {root['path']} [{status}, skills={root['skillCount']}]")
    print("tools:")
    for name, path in data["tools"].items():
        print(f"  - {name}: {path or 'missing'}")
    return 0


def bash_completion() -> str:
    skills = " ".join(skill_dirs())
    commands = "doctor list path completion"
    return f"""# bash completion for reverse-skill
_reverse_skill()
{{
  local cur cword
  cur="${{COMP_WORDS[COMP_CWORD]}}"
  cword="${{COMP_CWORD}}"

  local commands="{commands}"
  local skills="{skills}"

  if [[ $cword -eq 1 ]]; then
    COMPREPLY=( $(compgen -W "$commands $skills" -- "$cur") )
    return
  fi

  case "${{COMP_WORDS[1]}}" in
    completion)
      COMPREPLY=( $(compgen -W "bash" -- "$cur") )
      return
      ;;
    list)
      COMPREPLY=( $(compgen -W "$skills" -- "$cur") )
      return
      ;;
    path)
      if [[ $cword -eq 2 ]]; then
        COMPREPLY=( $(compgen -W "$skills" -- "$cur") )
      elif [[ $cword -eq 3 ]]; then
        COMPREPLY=( $(compgen -W "$(reverse-skill list "${{COMP_WORDS[2]}}" 2>/dev/null)" -- "$cur") )
      fi
      return
      ;;
    doctor)
      COMPREPLY=( $(compgen -W "--json" -- "$cur") )
      return
      ;;
  esac

  if [[ $cword -eq 2 ]]; then
    COMPREPLY=( $(compgen -W "$(reverse-skill list "${{COMP_WORDS[1]}}" 2>/dev/null)" -- "$cur") )
  fi
}}
complete -F _reverse_skill reverse-skill
"""


def completion(shell: str) -> int:
    if shell != "bash":
        raise SystemExit(f"Unsupported completion shell: {shell}\nAvailable shells: bash")
    print(bash_completion(), end="")
    return 0


def usage() -> int:
    print(
        "Usage:\n"
        "  reverse-skill doctor [--json]\n"
        "  reverse-skill completion bash\n"
        "  reverse-skill list [skill]\n"
        "  reverse-skill path <skill> <tool>\n"
        "  reverse-skill <skill> <tool> [args...]\n",
        file=sys.stderr,
    )
    return 2


def main(argv: list[str] | None = None) -> int:
    argv = list(sys.argv[1:] if argv is None else argv)
    if not argv:
        return usage()
    if argv[0] == "doctor":
        if len(argv) == 1:
            return doctor()
        if len(argv) == 2 and argv[1] == "--json":
            return doctor(json_output=True)
        return usage()
    if argv[0] == "completion":
        if len(argv) == 2:
            return completion(argv[1])
        return usage()
    if argv[0] == "list":
        if len(argv) == 1:
            return list_skills()
        if len(argv) == 2:
            return list_tools(argv[1])
        return usage()
    if argv[0] == "path":
        if len(argv) != 3:
            return usage()
        print(resolve_tool(argv[1], argv[2]))
        return 0
    if len(argv) < 2:
        return usage()
    path = resolve_tool(argv[0], argv[1])
    return subprocess.run(command_for(path, argv[2:])).returncode


if __name__ == "__main__":
    raise SystemExit(main())

#!/usr/bin/env python3
from __future__ import annotations

import os
import subprocess
import sys
from pathlib import Path


PLUGIN_NAME = "reverse-skills"


def repo_root() -> Path:
    return Path(__file__).resolve().parents[1]


def candidate_roots() -> list[Path]:
    home = Path.home()
    roots = [
        repo_root(),
        home / "plugins" / PLUGIN_NAME / "skills",
        home / ".codex" / "plugins" / "cache" / "personal" / PLUGIN_NAME,
    ]
    account_cache = home / ".codex-account-cli" / "homes"
    if account_cache.exists():
        roots.extend(account_cache.glob(f"*/plugins/cache/personal/{PLUGIN_NAME}/*/skills"))
    return roots


def skills_root(root: Path) -> Path:
    if (root / "skills").is_dir():
        return root / "skills"
    return root


def skill_dirs() -> dict[str, Path]:
    found: dict[str, Path] = {}
    for root in candidate_roots():
        base = skills_root(root)
        if not base.exists():
            continue
        for skill_file in base.glob("*/SKILL.md"):
            found.setdefault(skill_file.parent.name, skill_file.parent)
    return dict(sorted(found.items()))


def normalize_tool_name(name: str) -> list[str]:
    path = Path(name)
    if path.suffix:
        return [name]
    return [name, f"{name}.py", f"{name}.sh", f"{name}.js"]


def resolve_tool(skill: str, tool: str) -> Path:
    skills = skill_dirs()
    if skill not in skills:
        available = ", ".join(skills)
        raise SystemExit(f"Unknown skill: {skill}\nAvailable skills: {available}")
    scripts = skills[skill] / "scripts"
    for candidate in normalize_tool_name(tool):
        path = scripts / candidate
        if path.exists() and path.is_file():
            return path
    available = []
    if scripts.exists():
        for path in sorted(item for item in scripts.rglob("*") if item.is_file()):
            available.append(str(path.relative_to(scripts)))
    raise SystemExit(
        f"Unknown tool for {skill}: {tool}\nAvailable tools: {', '.join(available)}"
    )


def list_skills() -> int:
    for name in skill_dirs():
        print(name)
    return 0


def list_tools(skill: str) -> int:
    skills = skill_dirs()
    if skill not in skills:
        raise SystemExit(f"Unknown skill: {skill}")
    scripts = skills[skill] / "scripts"
    if not scripts.exists():
        return 0
    for path in sorted(item for item in scripts.rglob("*") if item.is_file()):
        rel = path.relative_to(scripts)
        if path.suffix in {".py", ".sh", ".js"}:
            print(str(rel.with_suffix("")))
        else:
            print(rel)
    return 0


def command_for(path: Path, args: list[str]) -> list[str]:
    if path.suffix == ".py":
        return ["python3", str(path), *args]
    if path.suffix == ".sh":
        return ["bash", str(path), *args]
    if os.access(path, os.X_OK):
        return [str(path), *args]
    return [str(path), *args]


def usage() -> int:
    print(
        "Usage:\n"
        "  reverse-skill list [skill]\n"
        "  reverse-skill path <skill> <tool>\n"
        "  reverse-skill <skill> <tool> [args...]\n",
        file=sys.stderr,
    )
    return 2


def main(argv: list[str] | None = None) -> int:
    argv = list(sys.argv[1:] if argv is None else argv)
    if not argv:
        return usage()
    if argv[0] == "list":
        if len(argv) == 1:
            return list_skills()
        if len(argv) == 2:
            return list_tools(argv[1])
        return usage()
    if argv[0] == "path":
        if len(argv) != 3:
            return usage()
        print(resolve_tool(argv[1], argv[2]))
        return 0
    if len(argv) < 2:
        return usage()
    path = resolve_tool(argv[0], argv[1])
    return subprocess.run(command_for(path, argv[2:])).returncode


if __name__ == "__main__":
    raise SystemExit(main())
